# InsuraMind local environment

# Spring Boot
SPRING_PROFILES_ACTIVE=local
BACKEND_PORT=8080
APP_JWT_SECRET=change-this-to-a-long-random-secret-change-this-to-a-long-random-secret
APP_INTERNAL_TOKEN=dev-internal-token-change-me
APP_CORS_ORIGINS=http://localhost:3000
AI_SERVICE_URL=http://localhost:8001

# Supabase PostgreSQL
# Flyway will create this schema in Supabase on startup.
APP_DB_SCHEMA=insuramind
# Replace this with your Supabase JDBC connection string.
SPRING_DATASOURCE_URL=jdbc:postgresql://db.<your-project-ref>.supabase.co:5432/postgres?sslmode=require
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=<supabase-db-password>
DATABASE_URL=jdbc:postgresql://db.<your-project-ref>.supabase.co:5432/postgres?sslmode=require

# MinIO / S3-compatible storage
MINIO_ENDPOINT=http://localhost:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=insuramind
MINIO_SECRET_KEY=insuramind-secret
MINIO_BUCKET=insuramind-documents

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=insuramind_chunks

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
APP_QUERY_CACHE_TTL_HOURS=24
APP_QUERY_RATE_LIMIT_PER_MINUTE=20

# AI
GEMINI_API_KEY=
GEMINI_FAST_MODEL=gemini-2.5-flash
GEMINI_REASONING_MODEL=gemini-2.5-pro
GEMINI_VERIFIER_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
EMBEDDING_DIM=1024

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8080/api
